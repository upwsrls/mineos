# ===========================================================================
# mineOS - .gitattributes
# Garantisce line ending corretti (LF) per gli script: un checkout su Windows
# con CRLF romperebbe gli shebang e i servizi systemd sul rig Linux.
# ===========================================================================

# Normalizzazione automatica del testo, sempre LF nel repository.
* text=auto eol=lf

# File che DEVONO restare LF (eseguiti su Linux).
*.sh        text eol=lf
*.service   text eol=lf
Makefile    text eol=lf
user-data   text eol=lf
meta-data   text eol=lf
*.conf      text eol=lf
*.example   text eol=lf

# File binari: nessuna conversione, nessun diff testuale.
*.iso       binary
*.tar.gz    binary
*.gz        binary
*.img       binary
